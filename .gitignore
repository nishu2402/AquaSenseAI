# ----------------------------------------------------------------------------
# AquaSense AI — .gitignore
# ----------------------------------------------------------------------------

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
out/
**/dist/
**/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output

# Vite / parcel / webpack caches
.vite/
.cache/
.parcel-cache/
.turbo/

# Environment
.env
.env.local
.env.*.local

# Editor / OS metadata
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Microsoft Office lock files (the ~$... files that appear when a doc is open)
~$*

# IDE — keep workspace settings shareable but ignore per-user state
.idea/
*.swp
*.swo
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Claude Code worktrees (transient, regenerated per session)
.claude/worktrees/

# Test artefacts
*.pdf.tmp
test-*.pdf
*.test.local
