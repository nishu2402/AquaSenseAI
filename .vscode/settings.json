{
  "files.exclude": {
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "javascript.validate.enable": true,
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": ["**/node_modules"]
  }
}
